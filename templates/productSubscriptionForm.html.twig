{% form_theme form '@SyliusShop/Form/theme.html.twig' %}
<div class="ui segment" style="margin-top: 5px">
    <div class="breadcrumb_notify" style="text-align: center;">
        {{ 'webgriffe_bisn.product_page.stock_notify_title'|trans|raw }}
    </div>

    {{ form_start(form, {
        'attr': {'class': 'ui form form-default', 'id': 'back_in_stock_not'},
        'action': path('webgriffe_back_in_stock_notification_add_subscription')
    }|merge(sylius_test_form_attribute('subscribe-to-notifications'))) }}

    <p style="display:none;">
        <label for="customer_email">Email : </label><input type="email" id="customer_email" name="customer_email">
    </p>

    {{ form_errors(form) }}

    {% if form.email is defined %}
        {{ form_widget(form.email, {'attr': {'data-test-fill-subscription-form-whit-my-email':'', 'class' : 'input m1', 'placeholder': 'Email'}}) }}
    {% endif %}

    {{ form_row(form.product_variant_code, {'attr': {
        'back-in-stock-notification-plugin-variant-code-input':''
    }}) }}

    {{ form_row(form.submit, {
        'attr': {'class': 'ui huge primary icon labeled button'},
    }) }}

    {{ form_row(form._token) }}
    {{ form_end(form, {'render_rest': false}) }}
</div>
